# Copy to .env and fill in. Never commit .env.
#
# ACTIVE STACK (no billing card anywhere):
#   discovery = OpenStreetMap Overpass (no key at all)
#   imagery   = Mapillary  (free token)
#   AI        = Qwen via DashScope (vision judge + image edit)

IMAGERY_SOURCE=mapillary        # mapillary | streetview
AI_PROVIDER=qwen                # qwen | gemini

# 1) Mapillary access token (free): mapillary.com -> sign in -> Settings -> Developers
#    -> Register application -> copy the Client Token.
MAPILLARY_TOKEN=

# 2) Qwen / DashScope API key: modelstudio console (Alibaba Cloud Model Studio)
#    International keys use the -intl endpoint below (default).
DASHSCOPE_API_KEY=
# DASHSCOPE_BASE=https://dashscope-intl.aliyuncs.com   # https://dashscope.aliyuncs.com for CN keys
# QWEN_VL_MODEL=qwen-vl-max
# QWEN_EDIT_MODEL=qwen-image-edit

# --- alternative stack (unused unless you flip the switches above) ---
# Google: enable Places API + Street View Static API, billing required (set quota caps)
GOOGLE_MAPS_API_KEY=
# Gemini: aistudio.google.com/apikey
GEMINI_API_KEY=
# JUDGE_MODEL=gemini-2.5-flash
# IMAGE_MODEL=gemini-2.5-flash-image
